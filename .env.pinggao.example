# Pinggao Cloud runtime environment variables
# Copy these keys into your cloud environment variable settings.

# Service
PORT=80
BASE_URL=http://127.0.0.1:80

# Tracking target-type priority (value desc under same threat level)
# Supports comma or '>' separators, e.g. 106,105,104,103 or 106>105>104>103
TRACKING_TARGET_TYPE_PRIORITY_ORDER=106,105,104,103
# Value score for target_type codes not listed above
TRACKING_TARGET_TYPE_OTHER_VALUE_SCORE=0

# External collaboration services (set MODE=http and BASE_URL when using real HTTP endpoints)
EXTERNAL_OPTRONIC_MODE=mock
EXTERNAL_OPTRONIC_BASE_URL=
EXTERNAL_OPTRONIC_TIMEOUT_SEC=3.0
EXTERNAL_MEDIA_MODE=mock
EXTERNAL_MEDIA_BASE_URL=
EXTERNAL_MEDIA_TIMEOUT_SEC=3.0
EXTERNAL_PLANNING_MODE=mock
EXTERNAL_PLANNING_BASE_URL=
EXTERNAL_PLANNING_TIMEOUT_SEC=3.0
EXTERNAL_SONAR_MODE=mock
EXTERNAL_SONAR_BASE_URL=
EXTERNAL_SONAR_TIMEOUT_SEC=3.0
EXTERNAL_AUTONOMY_MODE=mock
EXTERNAL_AUTONOMY_BASE_URL=
EXTERNAL_AUTONOMY_TIMEOUT_SEC=3.0

# DDS runtime mode
DDS_MODE=real
DDS_PLATFORM=linux
DDS_CONFIG_PATH=/app/config/dds_settings.yaml
DDS_DOMAIN_ID=001
DDS_QOS_PROFILE=Reliable
DDS_TOPIC_PREFIX=cc_cm_tracking_monitor_service.v1.
DDS_TOPIC_TASK_UPDATE=cc_cm_tracking_monitor_service.v1.task_update_topic
DDS_TOPIC_PREPLAN_RESULT=cc_cm_tracking_monitor_service.v1.preplan_result_topic
DDS_TOPIC_MANUAL_SELECTION_REQUEST=cc_cm_tracking_monitor_service.v1.manual_selection_request_topic
DDS_TOPIC_MANUAL_SWITCH_REQUEST=cc_cm_tracking_monitor_service.v1.manual_switch_request_topic
DDS_TOPIC_ELECTRO_OPTICAL_LINKAGE_CMD=cc_cm_tracking_monitor_service.v1.electro_optical_linkage_cmd_topic
DDS_TOPIC_STREAM_MEDIA_PARAM=cc_cm_tracking_monitor_service.v1.stream_media_param_topic
DDS_TOPIC_OWNSHIP_NAVIGATION=cc_cm_tracking_monitor_service.v1.ownship_navigation_topic
DDS_TOPIC_TARGET_PERCEPTION=cc_cm_tracking_monitor_service.v1.target_perception_topic
# Focus ownship/source platform id for DDS ingress filtering
DDS_FOCUS_PLATFORM_ID=1001

# DDS SDK paths
DDS_SDK_ROOT=/app/thirdparty/ljdds/DDSCore3.0.1
DDS_SDK_ARCH_DIR=ft2000KylinV10GFgcc9.3.0
DDS_QOS_FILE=/app/thirdparty/ljdds/DDSCore3.0.1/qosconf/example.xml
DDS_LICENSE_FILE=/app/thirdparty/ljdds/DDSCore3.0.1/ljddslicense.lic
DDS_LIB_DIR=/app/thirdparty/ljdds/DDSCore3.0.1/lib/ft2000KylinV10GFgcc9.3.0
LJDDSHOME=/app/thirdparty/ljdds/DDSCore3.0.1
LJDDS_HOME=/app/thirdparty/ljdds/DDSCore3.0.1

# Media
FFMPEG_BIN=ffmpeg
MEDIA_OUTPUT_DIR=artifacts/media

# Optional: keep this for DDS docker-license behavior if needed by your deployment
LJDDS_DOCKER_LIC=1
