### Scenario 1: create filtering task
POST {{baseUrl}}/tasks
Content-Type: {{json}}

{
  "task_id": "{{trackingFilterTaskId}}",
  "task_type": "tracking",
  "task_name": "tracking-filter-scenario",
  "task_source": "planning_service",
  "priority": 1,
  "mode": "escort",
  "target_info": {
    "target_type_code": 106,
    "enemy_friend_attr": 1,
    "military_civil_attr": 1
  },
  "task_area": {
    "area_type": "polygon",
    "points": [
      { "longitude": 121.49, "latitude": 31.20 },
      { "longitude": 121.52, "latitude": 31.20 },
      { "longitude": 121.52, "latitude": 31.24 },
      { "longitude": 121.49, "latitude": 31.24 }
    ]
  },
  "expected_speed": 11.0,
  "update_interval_sec": 1,
  "end_condition": {
    "duration_sec": 180,
    "out_of_region_finish": true
  }
}

### Scenario 1: inspect candidate ranking
GET {{baseUrl}}/tasks/{{trackingFilterTaskId}}/result

