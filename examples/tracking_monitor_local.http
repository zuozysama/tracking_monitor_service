@baseUrl = http://127.0.0.1:8080
@json = application/json
@taskId = task-tracking-002
@trackingFilterTaskId = task-tracking-filter-001
@trackingExpelTaskId = task-tracking-expel-001
@patrolTaskId = task-patrol-coverage-001
@preplanTaskId = task-preplan-001
@underwaterTaskId = task-underwater-001

### Service health
GET {{baseUrl}}/

### ====================
### Formal APIs in current version
### These are the interfaces that should be treated as the current official API surface.
### DDS topics mentioned in the document are not invoked directly from this .http file.
### The mock endpoints below are only local test helpers for this repository.
### ====================

### Create a basic tracking task
POST {{baseUrl}}/tasks
Content-Type: {{json}}

{
  "task_id": "{{taskId}}",
  "task_type": "tracking",
  "task_name": "tracking-basic-scenario",
  "task_source": "planning_service",
  "priority": 1,
  "mode": "escort",
  "target_info": {
    "target_id": "target-001",
    "target_batch_no": 1,
    "target_type_code": 106,
    "threat_level": 2,
    "target_name": "target-001",
    "military_civil_attr": 1
  },
  "task_area": {
    "area_type": "polygon",
    "points": [
      { "longitude": 121.49, "latitude": 31.21 },
      { "longitude": 121.52, "latitude": 31.21 },
      { "longitude": 121.52, "latitude": 31.23 },
      { "longitude": 121.49, "latitude": 31.23 }
    ]
  },
  "expected_speed": 12.0,
  "update_interval_sec": 1,
  "end_condition": {
    "duration_sec": 300,
    "out_of_region_finish": true
  },
  "stream_media_param": {
    "photo_enabled": true,
    "photo_interval_sec": 5,
    "video_enabled": true,
    "video_interval_sec": 10,
    "video_duration_sec": 10
  },
  "linkage_param": {
    "enable_optical": true,
    "enable_evidence": true
  }
}

### Query task status
GET {{baseUrl}}/tasks/{{taskId}}/status

### Query task formal output
GET {{baseUrl}}/tasks/{{taskId}}/output

### Query task result detail
GET {{baseUrl}}/tasks/{{taskId}}/result

### Request media stream access
POST {{baseUrl}}/media/stream/access
Content-Type: {{json}}

{
  "task_id": "{{taskId}}",
  "stream_type": "optical_video",
  "channel_id": "optical-001",
  "media_protocol": "webrtc",
  "request_time": "2026-03-24T10:01:20Z"
}

### Send manual target selection request
POST {{baseUrl}}/tasks/manual-selection/request
Content-Type: {{json}}

{
  "task_id": "{{taskId}}",
  "request_type": "manual_selection",
  "timeout_sec": 10,
  "candidate_targets": [
    {
      "target_id": "target-001",
      "target_batch_no": 1,
      "target_type_code": 106,
      "threat_level": 2,
      "target_name": "target-001",
      "military_civil_attr": 1
    },
    {
      "target_id": "target-002",
      "target_batch_no": 2,
      "target_type_code": 108,
      "threat_level": 3,
      "target_name": "target-002",
      "military_civil_attr": 1
    }
  ]
}

### Receive manual target selection feedback
POST {{baseUrl}}/tasks/manual-selection/feedback
Content-Type: {{json}}

{
  "task_id": "{{taskId}}",
  "selected_target_id": "target-002",
  "feedback_time": "2026-03-24T10:02:30Z"
}

### Send manual target switch request
POST {{baseUrl}}/tasks/manual-switch/request
Content-Type: {{json}}

{
  "task_id": "{{taskId}}",
  "request_type": "manual_switch",
  "timeout_sec": 10,
  "current_target_id": "target-002",
  "new_candidate_targets": [
    {
      "target_id": "target-003",
      "target_batch_no": 3,
      "target_type_code": 106,
      "threat_level": 2,
      "target_name": "target-003",
      "military_civil_attr": 1
    }
  ]
}

### Receive manual target switch feedback
POST {{baseUrl}}/tasks/manual-switch/feedback
Content-Type: {{json}}

{
  "task_id": "{{taskId}}",
  "selected_target_id": "target-003",
  "keep_current": false,
  "feedback_time": "2026-03-24T10:03:00Z"
}

### Create a preplan task
POST {{baseUrl}}/tasks
Content-Type: {{json}}

{
  "task_id": "{{preplanTaskId}}",
  "task_type": "preplan",
  "task_name": "preplan-basic-scenario",
  "task_area": {
    "area_type": "polygon",
    "points": [
      { "longitude": 121.49, "latitude": 31.21 },
      { "longitude": 121.52, "latitude": 31.21 },
      { "longitude": 121.52, "latitude": 31.23 },
      { "longitude": 121.49, "latitude": 31.23 }
    ]
  },
  "expected_speed": 10.0,
  "end_condition": {
    "duration_sec": 120
  }
}

### Query preplan output
GET {{baseUrl}}/tasks/{{preplanTaskId}}/output

### Query sonar match status
GET {{baseUrl}}/sonar/match/status?task_id={{underwaterTaskId}}

### Terminate the basic tracking task
POST {{baseUrl}}/tasks/{{taskId}}/terminate
Content-Type: {{json}}

{
  "reason": "cleanup"
}

### Terminate the preplan task
POST {{baseUrl}}/tasks/{{preplanTaskId}}/terminate
Content-Type: {{json}}

{
  "reason": "cleanup"
}

### ====================
### Local mock and DDS simulation helpers
### These endpoints are project-specific debug helpers.
### They are not the formal interface definition in the external document.
### Use them only for local integration testing in this repository.
### ====================

### Reset local mock DDS state
POST {{baseUrl}}/mock/dds/reset

### Simulate DDS ownship input
POST {{baseUrl}}/mock/dds/navigation
Content-Type: {{json}}

{
  "platform_id": 1001,
  "speed_mps": 6.2,
  "heading_deg": 90.0,
  "longitude": 121.5000000,
  "latitude": 31.2200000,
  "timestamp": "2026-03-24T10:00:00Z"
}

